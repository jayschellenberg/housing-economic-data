    "slos_business":           { "title": "SLOS — Business lending conditions","displayGroup": "credit_conditions", "order": 2 },
    "nhpi":                    { "title": "New Housing Price Index",                "displayGroup": "prices",            "order": 1, "snapshotPick": "statscan.nhpi.winnipeg" },
    "cpi_shelter":             { "title": "CPI — Shelter component",           "displayGroup": "prices",            "order": 2, "snapshotPick": "statscan.cpi_shelter.manitoba" },
    "permits_residential":     { "title": "Residential building permits ($)",       "displayGroup": "supply",            "order": 1, "snapshotPick": "statscan.permits.residential.manitoba" },
    "permits_nonresidential":  { "title": "Non-residential building permits ($)",   "displayGroup": "supply",            "order": 2, "snapshotPick": "statscan.permits.nonresidential.manitoba" }
