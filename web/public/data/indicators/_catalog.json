  "version": 2,
  "description": "Source-of-truth manifest for the Market Indicators tab. Every series has an expected title that the validator confirms against the live provider before scraping. chartId groups series that should render on the same chart panel; chartLabel is the legend label inside that chart. Unit codes map to formatters in web/src/indicator-chart.js: percent | dollar | dollar_millions | index | units | persons | ratio | balance_of_opinion.",
  "displayGroups": {
    "mortgage_market":     { "title": "Mortgage Market",      "order": 1 },
    "credit_conditions":   { "title": "Credit Conditions",    "order": 2 },
    "prices":              { "title": "Prices",               "order": 3 },
    "supply":              { "title": "Supply",               "order": 4 },
    "demand":              { "title": "Demand",               "order": 5 },
    "construction_cost":   { "title": "Construction Cost",    "order": 6 },
    "derived":             { "title": "Derived Indicators",   "order": 7 }
  },
  "charts": {
    "mortgage_rates":          { "title": "Posted mortgage rates",                  "displayGroup": "mortgage_market",   "order": 1, "snapshotPick": "boc.mortgage5yr" },
    "goc_yields":              { "title": "Government of Canada bond yields",       "displayGroup": "mortgage_market",   "order": 2, "snapshotPick": "boc.goc_5yr" },
    "policy_rates":            { "title": "Policy rate + CORRA",                    "displayGroup": "mortgage_market",   "order": 3, "snapshotPick": "boc.policy_target" },
    "arrears":                 { "title": "Mortgage arrears (90+ days)",            "displayGroup": "mortgage_market",   "order": 4 },
