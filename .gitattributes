# Normalize line endings to LF everywhere. Silences the "LF will be replaced by
# CRLF" warnings on Windows commits and keeps diffs consistent across machines.
* text=auto eol=lf

# Binary assets — never apply text/eol conversion.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.zip   binary
*.gdb   binary
*.xlsx  binary
*.xls   binary
